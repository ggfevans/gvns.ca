---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';
import { getPostSlug } from '@utils/content';
import type { AdjacentPost } from '@components/PostNav.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  const sorted = [...posts].sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  const toAdjacent = (entry: (typeof sorted)[number]): AdjacentPost => ({
    slug: getPostSlug(entry.id),
    title: entry.data.title,
    pubDate: entry.data.pubDate,
  });

  return sorted.map((post, index) => {
    const newer = index > 0 ? sorted[index - 1] : undefined;
    const older = index < sorted.length - 1 ? sorted[index + 1] : undefined;

    return {
      params: { slug: getPostSlug(post.id) },
      props: {
        post,
        prev: older ? toAdjacent(older) : undefined,
        next: newer ? toAdjacent(newer) : undefined,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);

// Mirror TableOfContents.svelte's `headings.length >= 3` threshold using the
// same rendered-heading source the TOC component reads from the DOM. Using
// `render()`'s headings (sourced from the markdown processor) avoids drift
// between layout decisions and TOC rendering on non-ATX heading syntax.
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;
---

<PostLayout post={post} prev={prev} next={next} showToc={showToc}>
  <Content />
</PostLayout>
