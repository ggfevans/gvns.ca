---
/**
 * Project component derived from @starwind-pro/footer-01.
 * Reference: (none — reference dir removed; re-add via
 *   `npx starwind@latest add @starwind-pro/footer-01` if needed for diff)
 * ADR: docs/DECISIONS.md#adr-018
 * Last upstream sync: 2026-04-28
 *
 * "Shell, not skin": keeps Footer 1's structure (border-t row of icons +
 * centred copyright) and bridges tokens via component-scoped CSS vars.
 * Link hovers respect per-page `data-accent` through `--colour-accent-primary`.
 */
import IconBrandGithub from "@tabler/icons/outline/brand-github.svg";
import IconBrandLinkedin from "@tabler/icons/outline/brand-linkedin.svg";
import IconBrandThreads from "@tabler/icons/outline/brand-threads.svg";
import IconMail from "@tabler/icons/outline/mail.svg";
import IconRss from "@tabler/icons/outline/rss.svg";

const currentYear = new Date().getFullYear();

// Astro's @tabler/icons/*.svg imports resolve to a renderable Astro component.
// Use typeof one of the icons to preserve type safety across the link list.
type IconComponent = typeof IconBrandGithub;

interface FooterLink {
    name: string;
    href: string;
    icon: IconComponent;
    external: boolean;
}

const links: FooterLink[] = [
    {
        name: "GitHub",
        href: "https://github.com/ggfevans",
        icon: IconBrandGithub,
        external: true,
    },
    {
        name: "Threads",
        href: "https://threads.net/@ggfevans",
        icon: IconBrandThreads,
        external: true,
    },
    {
        name: "LinkedIn",
        href: "https://linkedin.com/in/ggfevans",
        icon: IconBrandLinkedin,
        external: true,
    },
    { name: "Email", href: "/contact", icon: IconMail, external: false },
    { name: "RSS", href: "/rss.xml", icon: IconRss, external: false },
];
---

<footer class="gvns-footer @container w-full border-t py-12">
    <div class="mx-auto w-full max-w-7xl px-4">
        <div class="gvns-footer__inner">
            <ul class="gvns-footer-links flex gap-6">
                {
                    links.map((link) => (
                        <li>
                            <a
                                href={link.href}
                                class="gvns-footer-link transition-colors"
                                aria-label={
                                    link.external
                                        ? `${link.name} (opens in new tab)`
                                        : link.name
                                }
                                {...(link.external
                                    ? { target: "_blank", rel: "noopener noreferrer" }
                                    : {})}
                            >
                                <link.icon
                                    class="size-5.5"
                                    aria-hidden="true"
                                />
                            </a>
                        </li>
                    ))
                }
            </ul>

            <div class="gvns-footer__gradient" aria-hidden="true"></div>

            <p class="gvns-footer__legal">
                © {currentYear} Gareth Evans · code MIT · words CC BY 4.0
            </p>
        </div>
    </div>
</footer>

<style>
    .gvns-footer {
        margin-top: auto;
        border-color: var(--colour-border);
    }

    .gvns-footer__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.875rem;
    }

    .gvns-footer-links {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .gvns-footer-link {
        display: inline-flex;
        color: var(--colour-text-secondary);
        text-decoration: none;
        transition: color var(--transition-fast, 150ms ease);
    }

    .gvns-footer-link:hover,
    .gvns-footer-link:focus-visible {
        color: var(--colour-accent-primary);
    }

    .gvns-footer__gradient {
        width: 80px;
        height: 2px;
        background: var(--gvns-activity-gradient);
    }

    .gvns-footer__legal {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--colour-text-muted);
        letter-spacing: 0.02em;
        text-align: center;
        white-space: nowrap;
    }
</style>
