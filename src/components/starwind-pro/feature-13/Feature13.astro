---
import IconBrain from "@tabler/icons/outline/brain.svg";
import IconChartLine from "@tabler/icons/outline/chart-line.svg";
import IconCode from "@tabler/icons/outline/code.svg";
import IconShieldCheck from "@tabler/icons/outline/shield-check.svg";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

import { Badge } from "@/components/starwind/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { Image } from "@/components/starwind/image";

export interface BentoFeature {
  icon?: any;
  badge?: string;
  title: string;
  description: string;
  image?: {
    src: string;
    alt: string;
  };
}

interface Props extends HTMLAttributes<"section"> {
  /** Array of 4 bento features (layout: 2x+1x top row, 1x+2x bottom row) */
  features?: BentoFeature[];
}

const feature13Styles = tv({
  base: "@container mx-auto w-full max-w-6xl px-4 py-24",
});

const {
  features = [
    {
      icon: IconBrain,
      badge: "AI Powered",
      title: "Intelligent Automation",
      description:
        "Leverage AI to automate repetitive tasks and optimize workflows. Our machine learning models continuously improve based on your usage patterns.",
      image: {
        src: "https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&h=600&fit=crop",
        alt: "AI automation",
      },
    },
    {
      icon: IconShieldCheck,
      title: "Enterprise Security",
      description: "SOC 2 compliant with end-to-end encryption and comprehensive audit logs.",
    },
    {
      icon: IconChartLine,
      badge: "Analytics",
      title: "Real-time Insights",
      description:
        "Track every metric that matters with our comprehensive analytics dashboard. Visualize trends and make data-driven decisions.",
      image: {
        src: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=600&fit=crop",
        alt: "Analytics dashboard",
      },
    },
    {
      icon: IconCode,
      title: "Developer Tools",
      description: "Modern APIs, SDKs, and CLI tools designed for seamless integration.",
    },
  ],
  class: className,
  ...rest
} = Astro.props;
---

<section class={feature13Styles({ class: className })} {...rest}>
  <div class="grid gap-4 @2xl:grid-cols-3 @2xl:gap-5">
    {
      features.map((feature, index) => {
        const isWide = index === 0 || index === 2;
        const hasImage = !!feature.image;

        return hasImage ? (
          <Card
            class:list={[
              "group dark relative min-h-72 overflow-hidden rounded-2xl border-0 shadow-lg transition-shadow duration-300 hover:shadow-2xl @3xl:min-h-80",
              {
                "@2xl:col-span-2": isWide,
                "@2xl:col-span-1": !isWide,
                "@2xl:order-4": index === 2,
              },
            ]}
          >
            <Image
              src={feature.image!.src}
              alt={feature.image!.alt}
              class="absolute inset-0 size-full object-cover"
              loading="lazy"
            />
            <div class="from-card/90 via-card/70 to-primary-accent/30 absolute inset-0 bg-linear-to-t" />
            <div class="relative z-10 flex h-full flex-col justify-end p-6">
              {feature.badge && (
                <Badge class="border-primary-accent/30 bg-primary-accent/10 text-primary-accent mb-4 w-fit rounded-full border px-3 py-1 text-xs font-medium backdrop-blur-md">
                  {feature.badge}
                </Badge>
              )}
              <CardTitle class="text-foreground mb-2 text-xl font-bold @md:text-2xl">
                {feature.title}
              </CardTitle>
              <CardDescription class="text-muted-foreground max-w-md text-sm leading-relaxed @md:text-base">
                {feature.description}
              </CardDescription>
            </div>
          </Card>
        ) : (
          <Card
            class:list={[
              "group from-card to-card/40 relative flex min-h-72 flex-col justify-between overflow-hidden rounded-2xl bg-linear-to-br p-6 shadow-lg backdrop-blur-xl transition-shadow duration-300 hover:shadow-2xl @3xl:min-h-80 @3xl:p-8",
              {
                "@2xl:col-span-2": isWide,
                "@2xl:col-span-1": !isWide,
                "@2xl:order-3": index === 3,
              },
            ]}
          >
            <div>
              {feature.icon && (
                <div class="bg-primary-accent/10 ring-primary-accent/20 mb-6 inline-flex rounded-2xl p-4">
                  <feature.icon class="text-primary-accent size-8" aria-hidden="true" />
                </div>
              )}
            </div>
            <div>
              <CardTitle class="text-foreground mb-3 text-xl font-bold @3xl:text-2xl">
                {feature.title}
              </CardTitle>
              <CardDescription class="text-muted-foreground text-base leading-relaxed @3xl:text-lg">
                {feature.description}
              </CardDescription>
            </div>
          </Card>
        );
      })
    }
  </div>
</section>
