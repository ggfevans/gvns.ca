---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ReadingProgress from "@components/ReadingProgress.svelte";
import TableOfContents from "@components/TableOfContents.svelte";
import TagList from "@components/TagList.astro";
import PostNav, { type AdjacentPost } from "@components/PostNav.astro";
import { formatDate } from "@utils/date";
import { getReadingTime } from "@utils/reading-time";
import {
    articleSchema,
    breadcrumbSchema,
    normalizeSiteUrl,
    toJsonLd,
} from "@utils/json-ld";
import CopyCodeInit from "@components/CopyCodeInit.astro";
import SyndicationLinks from "@components/SyndicationLinks.astro";
import Comments from "@components/Comments.astro";
import { Image } from "astro:assets";
import "@styles/code-mockup.css";

interface Props {
    post: CollectionEntry<"posts">;
    prev?: AdjacentPost;
    next?: AdjacentPost;
    showToc?: boolean;
}

const { post, prev, next, showToc = false } = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage, heroImageAlt, syndication } = post.data;
const readingTime = getReadingTime(post.body ?? '');

const siteUrl = normalizeSiteUrl(Astro.site);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const articleJsonLd = toJsonLd(
    articleSchema({
        title,
        description,
        pubDate,
        updatedDate,
        url: canonicalUrl,
        siteUrl,
    }),
);

const breadcrumbJsonLd = toJsonLd(
    breadcrumbSchema([
        { name: "Home", url: siteUrl },
        { name: "Posts", url: `${siteUrl}/posts` },
        { name: title, url: canonicalUrl },
    ]),
);
---

<BaseLayout
    title={title}
    description={description}
    image={heroImage?.src}
    imageAlt={heroImageAlt}
    imageWidth={heroImage?.width}
    imageHeight={heroImage?.height}
    accent="p4-amber"
    breadcrumbs={[
        { label: "Home", href: "/" },
        { label: "Posts", href: "/posts" },
        { label: title },
    ]}
>
    <script type="application/ld+json" set:html={articleJsonLd} slot="head" />
    <script
        type="application/ld+json"
        set:html={breadcrumbJsonLd}
        slot="head"
    />
    <ReadingProgress client:idle />
    <main id="main-content" data-pagefind-body>
        <article class="gvns-post">
            {heroImage && (
                <figure class="gvns-post-hero">
                    <Image
                        src={heroImage}
                        alt={heroImageAlt ?? ''}
                        loading="eager"
                        fetchpriority="high"
                        widths={[480, 800, 1200, 1800]}
                        sizes="(min-width: 1200px) 1100px, 100vw"
                    />
                </figure>
            )}
            <header class="gvns-post-header">
                <h1>{title}</h1>
                <div class="gvns-post-meta">
                    <time datetime={pubDate.toISOString()}>
                        {formatDate(pubDate)}
                    </time>
                    <span class="gvns-post-reading-time">{readingTime} min read</span>
                </div>
                {
                    updatedDate && (
                        <p class="gvns-post-updated">
                            Last updated{' '}
                            <time datetime={updatedDate.toISOString()}>
                                {formatDate(updatedDate)}
                            </time>
                        </p>
                    )
                }
                <TagList tags={tags} />
            </header>

            <div class:list={["gvns-post-shell", { "gvns-post-shell--with-toc": showToc }]}>
                <div class="gvns-post-content">
                    <div class="prose">
                        <slot />
                    </div>
                    <CopyCodeInit />
                    <SyndicationLinks
                        syndication={syndication}
                        postUrl={canonicalUrl}
                        postTitle={title}
                    />
                    <Comments post={post} />
                    <PostNav prev={prev} next={next} />
                    <footer class="gvns-post-footer">
                        <a href="/posts">&larr; Back to all posts</a>
                    </footer>
                </div>
                {showToc && (
                    <aside class="gvns-post-sidebar" aria-label="Article navigation">
                        <div class="gvns-post-sidebar-sticky">
                            <TableOfContents client:idle />
                        </div>
                    </aside>
                )}
            </div>
        </article>
    </main>
</BaseLayout>

<style>
    /* Outer wrapper allows wide grid; inner columns enforce 65ch reading. */
    .gvns-post {
        max-width: var(--width-wide, 80rem);
        margin: 0 auto;
    }

    .gvns-post-hero {
        margin: 0 auto 2rem;
        max-width: var(--width-content);
    }

    .gvns-post-hero img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: var(--radius-lg);
    }

    .gvns-post-header {
        margin: 0 auto 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--colour-border);
        max-width: var(--width-content);
    }

    .gvns-post-header h1 {
        font-size: var(--text-4xl);
        line-height: 1.2;
        letter-spacing: -0.01em;
        margin-bottom: 0.75rem;
    }

    .gvns-post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        font-size: 0.875rem;
        color: var(--colour-text-secondary);
        margin-bottom: 0.5rem;
    }

    .gvns-post-reading-time::before {
        content: "·";
        margin-right: 1rem;
    }

    .gvns-post-updated {
        font-size: 0.8125rem;
        font-style: italic;
        color: var(--colour-text-secondary);
        margin: 0 0 0.75rem;
    }

    /* Shell: single content track by default; 2-col TOC grid only when showToc. */
    .gvns-post-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 2rem;
    }

    .gvns-post-shell--with-toc {
        grid-template-areas:
            "sidebar"
            "content";
    }

    .gvns-post-content {
        min-width: 0;
        max-width: var(--width-content);
        margin-inline: auto;
        width: 100%;
    }

    .gvns-post-shell--with-toc .gvns-post-content {
        grid-area: content;
    }

    .gvns-post-shell--with-toc .gvns-post-sidebar {
        grid-area: sidebar;
        min-width: 0;
    }

    @media (min-width: 1024px) {
        .gvns-post-shell--with-toc {
            grid-template-columns: minmax(0, 1fr) 240px;
            grid-template-areas: "content sidebar";
            gap: 3rem;
            align-items: start;
        }

        /* Content anchors left of its grid column when paired with the sidebar. */
        .gvns-post-shell--with-toc .gvns-post-content {
            margin-inline: 0;
        }

        .gvns-post-shell--with-toc .gvns-post-sidebar-sticky {
            position: sticky;
            top: 5rem;
            max-height: calc(100vh - 6rem);
            overflow-y: auto;
        }
    }

    .gvns-post-footer {
        margin-top: 2rem;
        padding-top: 1rem;
    }

    .gvns-post-footer a {
        color: var(--colour-accent-primary);
        text-decoration: none;
        transition: color var(--transition-fast);
        font-size: 0.875rem;
    }

    .gvns-post-footer a:hover {
        color: var(--colour-accent-hover);
    }
</style>
