# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# internal docs scratch — canonical docs (top-level docs/*.md) are tracked
docs/.claude/
docs/notes/
docs/plans/
docs/research/
docs/superpowers/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
.env.local
.dev.vars

# macOS-specific files
.DS_Store

# editor / IDE — Starwind init drops a snippets file here, but it's not project-specific
.vscode/

# git worktrees
.worktree/
.worktrees/

# claude-mem context files (keep root CLAUDE.md, ignore all others)
**/CLAUDE.md
!/CLAUDE.md
.worktrees
.claude/worktrees/
.claude/spike-*-checkpoint.yaml
.claude/spike-*-issues.yaml

# wrangler local state
.wrangler/
