@jsr:registry=https://npm.jsr.io
# @unpic/astro@1.0.2 declares its peer range as astro@^2 || ^3 || ^4 || ^5.0.0-beta;
# Astro 6 isn't listed yet but the runtime API used (getURL/getHTMLAttributes) is unchanged.
# Required for `npm install` (Workers Builds) — `npm ci` ignores peer-dep resolution anyway.
# Drop once @unpic/astro lists Astro 6 in its peer range. See ADR-018.
legacy-peer-deps=true
